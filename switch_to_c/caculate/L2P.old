#include "fmm.h"
#include "operators.h"

void L2P(const HilbertTree *tree, int leaf_id, double complex *local_exp){
    if (tree->node_start[leaf_id] > tree->node_end[leaf_id])
        return;

    double complex *dz = (double complex *)malloc(sizeof(double complex) * (tree->node_end[leaf_id] - tree->node_start[leaf_id] + 1));
    for (int i = 0; i < tree->node_end[leaf_id] - tree->node_start[leaf_id] + 1; i++){
        dz[i] = (tree->sort_x[tree->node_start[leaf_id] + i] - tree->node_cx[leaf_id])
                     + I * (tree->sort_y[tree->node_start[leaf_id] + i] - tree->node_cy[leaf_id]);
    }
    
    /* 計算勢能: Phi(z) = Re( sum( b_k * (z - z_c)^k ) ) */
    double complex *pot = (double complex *)malloc(sizeof(double complex) * (tree->node_end[leaf_id] - tree->node_start[leaf_id] + 1));
    double complex dz_pow = 1;
    for (int k = 0; k < MAX_P; k++){
        pot[k] += local_exp[leaf_id * MAX_P + k] * dz_pow;
        dz_pow *= dz[k];
    }
    for (int i = 0; i < tree->node_end[leaf_id] - tree->node_start[leaf_id] + 1; i++){
        tree->sort_potential[tree->node_start[leaf_id] + i] += G_CONST * creal(pot[i]);
    }

    /* 計算受力 (勢能的負梯度): F = -conj( dPhi/dz ) */
    double complex *force = (double complex *)malloc(sizeof(double complex) * (tree->node_end[leaf_id] - tree->node_start[leaf_id] + 1));
    dz_pow = 1;
    for (int k = 1; k < MAX_P; k++){
        force[k] += (double complex)k * local_exp[leaf_id * MAX_P + k] * dz_pow;
        dz_pow *= dz[k];
    }
    for (int i = 0; i < tree->node_end[leaf_id] - tree->node_start[leaf_id] + 1; i++){
        tree->sort_fx[tree->node_start[leaf_id] + i] -= G_CONST * creal(force[i]);
        tree->sort_fy[tree->node_start[leaf_id] + i] += G_CONST * cimag(force[i]);
    }
    free(dz);
    free(pot);
    free(force);
}

/*
 * Local-to-Particle：從局部展開係數計算葉節點每個粒子的勢能和力。
 *   phi = Re( sum_k b[k] * (z - z_c)^k )
 *   F   = -conj( dPhi/dz )
 *  Working
 */